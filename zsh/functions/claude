#!/usr/bin/env zsh
local CLAUDE_THEME="light-ansi"

if [[ "$PLATFORM" == "macos" ]] && command -v defaults &>/dev/null; then
  if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
    CLAUDE_THEME="dark-ansi"
  else
    CLAUDE_THEME="light-ansi"
  fi
elif [[ -f /proc/sys/fs/binfmt_misc/WSLInterop || -n "$WSL_DISTRO_NAME" ]]; then
  local reg_val
  reg_val="$(/mnt/c/Windows/System32/reg.exe query \
    'HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize' \
    /v AppsUseLightTheme 2>/dev/null | grep -oP '0x\d+')"
  if [[ "$reg_val" == "0x0" ]]; then
    CLAUDE_THEME="dark-ansi"
  else
    CLAUDE_THEME="light-ansi"
  fi
fi

# Update ~/.claude.json theme before launching
local SETTINGS="$HOME/.claude.json"
if command -v jq &>/dev/null; then
  if [[ -f "$SETTINGS" ]]; then
    jq --arg theme "$CLAUDE_THEME" '. + {theme: $theme}' "$SETTINGS" > "$SETTINGS.tmp" && mv "$SETTINGS.tmp" "$SETTINGS"
  else
    echo "{\"theme\": \"$CLAUDE_THEME\"}" > "$SETTINGS"
  fi
fi

command claude "$@"
