# Brewfile for Linux/WSL
# Install Homebrew on Linux: https://docs.brew.sh/Homebrew-on-Linux
# Usage: brew bundle --file=~/.Brewfile.linux

tap "roborev-dev/tap"

# CLI Tools & Development
brew "act"
brew "argocd"
brew "autoconf"
brew "automake"
brew "awscli"
brew "biome"
brew "caddy"
brew "cairo"
brew "calicoctl"
brew "cmake"
brew "coreutils"
brew "ctags"
brew "curl"
brew "doctl"
brew "eksctl"
brew "flux"
brew "flyctl"
brew "gemini-cli"
brew "gh"
brew "git"
brew "glab"
brew "gnupg"
brew "hivemind"
brew "htop"
brew "httpie"
brew "hyperfine"
brew "iftop"
brew "imagemagick"
brew "iperf3"
brew "jq"
brew "just"
brew "k6"
brew "kind"
brew "kops"
brew "kubectx"
brew "kubeseal"
brew "kubie"
brew "kustomize"
brew "linkerd"
brew "markdownlint-cli2"
brew "minikube"
brew "mkcert"
brew "nats-server"
brew "nginx"
brew "openssl"
brew "overmind"
brew "pnpm"
brew "podman"
brew "rcm"
brew "redis"
brew "roborev-dev/tap/roborev"
brew "rustup"
brew "semgrep"
brew "shellcheck"
brew "sops"
brew "sox"
brew "step"
brew "stern"
brew "tmux"
brew "tree"
brew "unzip"
